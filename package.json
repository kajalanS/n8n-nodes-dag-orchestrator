{
  "name": "@ksoftm/n8n-nodes-dag-orchestrator",
  "version": "1.4.0",
  "description": "Blueprint-Style DAG Workflow Orchestrator for n8n",
  "main": "dist/nodes/DagOrchestrator/DagSplit.node.js",
  "scripts": {
    "build": "tsc && node ./scripts/copy-assets.js",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "prepare": "npm run build",
    "test": "jest"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "n8n-community-node-package",
    "dag",
    "parallel",
    "orchestrator",
    "blueprint",
    "n8n"
  ],
  "author": "",
  "license": "MIT",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [],
    "nodes": [
      "dist/nodes/DagOrchestrator/DagSplit.node.js",
      "dist/nodes/DagOrchestrator/DagTry.node.js",
      "dist/nodes/DagOrchestrator/DagCatch.node.js",
      "dist/nodes/DagOrchestrator/DagFinally.node.js",
      "dist/nodes/DagOrchestrator/DagJoin.node.js",
      "dist/nodes/DagOrchestrator/DagLoop.node.js",
      "dist/nodes/DagOrchestrator/DagGroup.node.js"
    ]
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "jest": "^30.3.0",
    "n8n-core": "*",
    "n8n-workflow": "*",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.0"
  }
}