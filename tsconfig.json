{
  "compilerOptions": {
    "typeRoots": [
      "./node_modules/@types",
      "./nodes/DagOrchestrator/types"
    ],
    "target": "ES2021",
    "module": "node16",
    "lib": [
      "ES2021"
    ],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "nodes/**/*.ts",
    "credentials/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts"
  ]
}